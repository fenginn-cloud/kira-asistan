{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "expo-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8081"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "web-dist",
      "runtimeExecutable": "node",
      "runtimeArgs": ["serve-dist.js"],
      "port": 8090,
      "autoPort": false
    }
  ]
}
